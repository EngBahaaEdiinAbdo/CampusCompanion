<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/background">

    <TextView
        android:id="@+id/txtDetailsTaskTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Task"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"/>

    <TextView
        android:id="@+id/txtDetailsTaskDue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Due"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_below="@id/txtDetailsTaskTitle"
        android:layout_marginTop="12dp"/>

    <TextView
        android:id="@+id/txtDetailsTaskStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Open"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_below="@id/txtDetailsTaskDue"
        android:layout_marginTop="6dp"/>

    <Button
        android:id="@+id/btnEditTask"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:layout_below="@id/txtDetailsTaskStatus"
        android:layout_marginTop="28dp"
        android:text="Edit"/>
</RelativeLayout>
